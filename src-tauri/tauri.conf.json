{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lumous",
  "version": "1.3.0",
  "identifier": "io.github.fogside.lumous",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lumous",
        "width": 1200,
        "height": 800,
        "minWidth": 280,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg4QjBDRUM3RUEzOUJCODYKUldTR3V6bnF4ODZ3aUFBTVBuTjhiekJTUHRFaDJmemFtbHZURlpLTDZ6bGh1NXIrbzJZYUNhMm8K",
      "endpoints": [
        "https://github.com/fogside/Lumous/releases/latest/download/latest.json"
      ]
    }
  }
}
